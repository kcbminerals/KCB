SESSION_SECRET=replace-with-a-long-random-string

# Required — the app stores all its data in a Google Sheet.
# See README for the full setup steps (create a Google Cloud service
# account, share your Sheet with it, and copy these three values).
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=the-id-from-your-google-sheet-url

# Optional — enables the automatic daily backup (see README "Backups").
# Any long random string; Vercel sends it with each scheduled backup run.
# BLOB_READ_WRITE_TOKEN is added automatically when you connect a Vercel
# Blob store to the project — don't fill it in by hand.
CRON_SECRET=replace-with-another-long-random-string
