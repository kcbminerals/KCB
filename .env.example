SESSION_SECRET=replace-with-a-long-random-string

# Only needed when deploying to a host without a persistent filesystem
# (e.g. Vercel). Leave both unset for local development or for hosts
# with real disk (Render, Railway, Fly.io, a VPS) — the app falls back
# to a local SQLite file at data/app.db.
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=replace-with-your-turso-auth-token
